meta {
  name: Batch Upload
  type: http
  seq: 1
}

post {
  url: https://skills-marketplace-api.vercel.app/api/upload/batch
  body: json
  auth: inherit
}

body:json {
  {
    "skills": [
      {
        "name": "my-skill",
