            "path": "SKILL.md",
            "content": "LS0tCm5hbWU6IE15IFNraWxsCmRlc2NyaXB0aW9uOiBBIHNhbXBsZSBza2lsbAotLS0KCkluc3RydWN0aW9ucyBoZXJl"
          }
        ]
      }
    ],
    "agents": [],
    "rules": []
  }
}

settings {
  encodeUrl: true
  timeout: 0
}